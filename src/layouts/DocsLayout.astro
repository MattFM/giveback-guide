---
import BaseHead from "../components/layout/BaseHead.astro";

interface Frontmatter {
  title: string;
  description?: string;
  image?: string;
  sidebar?: boolean;
  toc?: boolean;
}

interface Props {
  title?: string;
  description?: string;
  image?: string;
  sidebar?: boolean;
  toc?: boolean;
  frontmatter?: Frontmatter;
}

// Support both direct props and frontmatter from MDX
const frontmatter = Astro.props.frontmatter;
const {
  title = frontmatter?.title || "Documentation",
  description = frontmatter?.description || "Documentation for Giveback Guide",
  image = frontmatter?.image,
  sidebar = frontmatter?.sidebar ?? true,
  toc = frontmatter?.toc ?? true,
} = Astro.props;

const currentPath = Astro.url.pathname;

// Auto-generate navigation from docs MDX files
const docsFiles = import.meta.glob<{ frontmatter: Frontmatter }>(
  "/src/pages/docs/**/*.mdx",
  { eager: true }
);

// Humanize directory names (e.g., "for-organisers" -> "For Organisers")
function humanize(str: string): string {
  return str
    .replace(/-/g, " ")
    .replace(/_/g, " ")
    .replace(/\b\w/g, (c) => c.toUpperCase());
}

// Build navigation structure from files
const sectionMap = new Map<string, { title: string; href: string }[]>();

Object.entries(docsFiles).forEach(([filePath, module]) => {
  const frontmatter = module.frontmatter;
  if (!frontmatter?.title) return;

  // Extract path parts: /src/pages/docs/about/mission-charter.mdx -> ['about', 'mission-charter.mdx']
  const pathMatch = filePath.match(/\/docs\/(.+)\.mdx$/);
  if (!pathMatch) return;

  const fullPath = pathMatch[1];
  const parts = fullPath.split("/");

  // Determine section and page path
  let section: string;
  let pagePath: string;

  if (parts.length === 1) {
    // Root level file (e.g., docs/index.mdx or docs/some-page.mdx)
    // Treat root level as its own section or skip if needed
    section = parts[0] === "index" ? "Overview" : parts[0];
    pagePath = parts[0] === "index" ? "/docs/" : `/docs/${parts[0]}/`;
  } else {
    // Nested: section/page.mdx
    section = parts[0];
    const fileName = parts[parts.length - 1];
    pagePath = `/docs/${fullPath}/`;
  }

  // Skip if already processed (shouldn't happen with unique paths)
  if (!sectionMap.has(section)) {
    sectionMap.set(section, []);
  }

  const items = sectionMap.get(section)!;
  
  // Check if this is an index/overview page
  const isIndex = parts[parts.length - 1] === "index";
  
  // Add to items (will sort later)
  items.push({
    title: isIndex ? "Overview" : frontmatter.title,
    href: pagePath,
  });
});

// Convert map to sorted nav sections
const navSections = Array.from(sectionMap.entries())
  .map(([sectionKey, items]) => {
    // Sort items: index/Overview first, then alphabetically
    const sortedItems = items.sort((a, b) => {
      if (a.title === "Overview") return -1;
      if (b.title === "Overview") return 1;
      return a.title.localeCompare(b.title);
    });

    return {
      title: humanize(sectionKey),
      items: sortedItems,
    };
  })
  // Sort sections alphabetically, but put "Overview" (root docs) first if it exists
  .sort((a, b) => {
    if (a.title === "Overview") return -1;
    if (b.title === "Overview") return 1;
    return a.title.localeCompare(b.title);
  });

// Extract headings from slot content for TOC
// This is a simple extraction - in production you'd want more robust parsing
const tocItems = [];
---

