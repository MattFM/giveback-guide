---
import DocsLayout from "../../layouts/DocsLayout.astro";
---

<DocsLayout
    title="Search Documentation"
    description="Search Giveback Guide documentation"
    sidebar={true}
    toc={false}
>
    <div
        class="search-container"
        data-pagefind-body
        data-pagefind-filter="type:doc"
    >
        <!-- Search Input -->
        <div class="search-box">
            <div class="input-wrapper">
                <svg
                    class="search-icon"
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.3-4.3"></path>
                </svg>
                <input
                    type="text"
                    id="search-input"
                    class="search-input"
                    placeholder="Search docs..."
                    autocomplete="off"
                />
                <button
                    id="clear-search"
                    class="clear-button hidden"
                    aria-label="Clear search"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="M18 6 6 18"></path>
                        <path d="m6 6 12 12"></path>
                    </svg>
                </button>
            </div>
            <div class="search-shortcut">
                <kbd>↵</kbd> to search
            </div>
        </div>

        <!-- Results -->
        <div id="search-results" class="results-container">
            <!-- Results will be inserted here by JavaScript -->
        </div>

        <!-- Status Messages -->
        <div id="status-message" class="status-message">
            Enter a search term to find documentation articles.
        </div>

        <!-- No Results -->
        <div id="no-results" class="no-results hidden">
            <div class="no-results-icon">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="48"
                    height="48"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.3-4.3"></path>
                    <path d="M8 8l6 6"></path>
                    <path d="m14 8-6 6"></path>
                </svg>
            </div>
            <h3>No results found</h3>
            <p>Try adjusting your search terms.</p>
        </div>
    </div>

    <script>
        // Search functionality using Pagefind
        let pagefind;
        let currentQuery = "";

        async function initPagefind() {
            try {
                // Use Function constructor to create truly dynamic import that Vite won't analyze at build time
                const importPath = "/pagefind/pagefind.js";
                const dynamicImport = new Function(
                    "path",
                    "return import(path)",
                );
                const pagefindModule = await dynamicImport(importPath);
                pagefind = pagefindModule;
                await pagefind.init();
                console.log("Pagefind initialized for docs search");

                // Update status if pagefind loaded successfully
                const statusEl = document.getElementById("status-message");
                if (statusEl && statusEl.textContent.includes("unavailable")) {
                    showStatus(
                        "Enter a search term to find documentation articles.",
                    );
                }
                
                // Return true to indicate successful initialization
                return true;
            } catch (error) {
                console.error("Failed to initialize Pagefind:", error);
                showStatus(
                    "Search index not available. Please run 'npm run build' first, or try searching from the production site.",
                );
                return false;
            }
        }

        function showStatus(message) {
            const statusEl = document.getElementById("status-message");
            const resultsEl = document.getElementById("search-results");
            const noResultsEl = document.getElementById("no-results");

            statusEl.textContent = message;
            statusEl.classList.remove("hidden");
            resultsEl.innerHTML = "";
            noResultsEl.classList.add("hidden");
        }

        function showNoResults() {
            const statusEl = document.getElementById("status-message");
            const resultsEl = document.getElementById("search-results");
            const noResultsEl = document.getElementById("no-results");

            statusEl.classList.add("hidden");
            resultsEl.innerHTML = "";
            noResultsEl.classList.remove("hidden");
        }

        function displayResults(results) {
            const statusEl = document.getElementById("status-message");
            const resultsEl = document.getElementById("search-results");
            const noResultsEl = document.getElementById("no-results");

            statusEl.classList.add("hidden");
            noResultsEl.classList.add("hidden");

            if (results.length === 0) {
                showNoResults();
                return;
            }

            resultsEl.innerHTML = results
                .map(
                    (result) => `
        <article class="result-item">
          <h3 class="result-title">
            <a href="${result.url}">${result.title}</a>
          </h3>
          <p class="result-excerpt">${result.excerpt}</p>
          <div class="result-meta">
            <span class="result-url">${result.url}</span>
          </div>
        </article>
      `,
                )
                .join("");
        }

        async function performSearch(query) {
            if (!pagefind || !query.trim()) {
                showStatus(
                    "Enter a search term to find documentation articles.",
                );
                return;
            }

            try {
                // First, try searching without filter to see if content exists
                console.log("Searching for:", query);
                const allSearch = await pagefind.search(query);
                console.log(
                    "Total results without filter:",
                    allSearch.results.length,
                );

                // Search with filter to only get docs pages
                const search = await pagefind.search(query, {
                    filters: {
                        type: "doc",
                    },
                });
                console.log(
                    "Results with type:doc filter:",
                    search.results.length,
                );

                if (search.results.length === 0) {
                    showNoResults();
                    return;
                }

                // Process results
                const processedResults = await Promise.all(
                    search.results.map(async (result) => {
                        const data = await result.data();
                        console.log("Result:", data.url, data.meta?.title);
                        return {
                            title: data.meta?.title || data.title || "Untitled",
                            excerpt: data.excerpt || "",
                            url: data.url,
                        };
                    }),
                );

                displayResults(processedResults);
            } catch (error) {
                console.error("Search error:", error);
                showStatus(
                    "An error occurred while searching. Please try again.",
                );
            }
        }

        // Initialize
        const urlParams = new URLSearchParams(window.location.search);
        const initialQuery = urlParams.get("q");
        
        // Input handling - set up immediately
        const searchInput = document.getElementById("search-input");
        const clearButton = document.getElementById("clear-search");

        searchInput?.addEventListener("input", (e) => {
            const value = e.target.value;
            if (value.length > 0) {
                clearButton?.classList.remove("hidden");
            } else {
                clearButton?.classList.add("hidden");
                showStatus(
                    "Enter a search term to find documentation articles.",
                );
            }
        });

        searchInput?.addEventListener("keydown", (e) => {
            if (e.key === "Enter") {
                currentQuery = e.target.value;
                performSearch(currentQuery);
            }
        });

        clearButton?.addEventListener("click", () => {
            if (searchInput) {
                searchInput.value = "";
                searchInput.focus();
                clearButton.classList.add("hidden");
                showStatus(
                    "Enter a search term to find documentation articles.",
                );
            }
        });
        
        // Initialize Pagefind, then run initial search if query exists
        initPagefind().then((initialized) => {
            if (initialized && initialQuery) {
                searchInput.value = initialQuery;
                clearButton?.classList.remove("hidden");
                currentQuery = initialQuery;
                performSearch(initialQuery);
            }
        });
    </script>

    <style>
        .search-container {
            max-width: 800px;
            margin: 0 auto;
        }

        .search-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .search-header h1 {
            font-size: 2rem;
            font-weight: 800;
            color: #111827;
            margin: 0 0 0.5rem 0;
        }

        .search-header p {
            color: #6b7280;
            font-size: 1.125rem;
        }

        /* Search Box */
        .search-box {
            margin-bottom: 1.5rem;
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .search-icon {
            position: absolute;
            left: 1rem;
            color: #9ca3af;
        }

        .search-input {
            width: 100%;
            padding: 1rem 3rem;
            font-size: 1rem;
            border: 2px solid #e5e7eb;
            border-radius: 0.75rem;
            background: white;
            transition:
                border-color 0.2s,
                box-shadow 0.2s;
        }

        .search-input:focus {
            outline: none;
            border-color: #7c3aed;
            box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
        }

        .clear-button {
            position: absolute;
            right: 1rem;
            background: none;
            border: none;
            color: #9ca3af;
            cursor: pointer;
            padding: 0.25rem;
            border-radius: 0.25rem;
            transition: color 0.2s;
        }

        .clear-button:hover {
            color: #374151;
        }

        .search-shortcut {
            text-align: center;
            margin-top: 0.5rem;
            color: #9ca3af;
            font-size: 0.875rem;
        }

        kbd {
            background: #f3f4f6;
            padding: 0.125rem 0.375rem;
            border-radius: 0.25rem;
            font-family: inherit;
            font-size: 0.875rem;
        }

        /* Results */
        .results-container {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .result-item {
            padding: 1.25rem;
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 0.75rem;
            transition:
                border-color 0.2s,
                box-shadow 0.2s;
        }

        .result-item:hover {
            border-color: #7c3aed;
            box-shadow: 0 2px 8px rgba(124, 58, 237, 0.1);
        }

        .result-title {
            font-size: 1.125rem;
            font-weight: 600;
            margin: 0 0 0.5rem 0;
        }

        .result-title a {
            color: #111827;
            text-decoration: none;
            border-bottom: 1px solid transparent;
            transition: border-color 0.2s;
        }

        .result-title a:hover {
            border-bottom-color: #7c3aed;
            color: #7c3aed;
        }

        .result-excerpt {
            color: #6b7280;
            font-size: 0.875rem;
            line-height: 1.6;
            margin: 0 0 0.75rem 0;
        }

        .result-meta {
            font-size: 0.75rem;
            color: #9ca3af;
        }

        .result-url {
            font-family:
                ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        }

        /* Status Messages */
        .status-message {
            text-align: center;
            padding: 3rem 1rem;
            color: #9ca3af;
        }

        .no-results {
            text-align: center;
            padding: 3rem 1rem;
        }

        .no-results-icon {
            color: #d1d5db;
            margin-bottom: 1rem;
        }

        .no-results h3 {
            font-size: 1.25rem;
            font-weight: 600;
            color: #374151;
            margin: 0 0 0.5rem 0;
        }

        .no-results p {
            color: #9ca3af;
        }

        .hidden {
            display: none !important;
        }
    </style>
</DocsLayout>
